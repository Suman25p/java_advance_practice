<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
	
	<bean id ="acc1" class ="com.kodewala.pojo.Account" >
	<property name = "firstName" value = "Kodewala"/>
	<property name = "lastName" value = "Academy"/>
	</bean>
	
	<bean id ="acc2" class ="com.kodewala.pojo.Account" >
	<property name = "accountNumber" value = "123456"/>
	<property name = "amount" value = "5000"/>
	</bean>
	
</beans>